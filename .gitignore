# --- 依赖目录 (最重要，千万别传) ---
node_modules/
.pnpm-store/

# --- 构建输出目录 (Cloudflare 会自动生成，无需上传) ---
docs/.vitepress/dist/
dist/

# --- 系统临时文件 ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- 编辑器配置 (可选，建议忽略以保持团队一致) ---
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 环境变量 (如果您以后要加 API 密钥，千万别传) ---
.env
.env.local
.env.*.local